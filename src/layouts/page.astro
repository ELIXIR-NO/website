---
import BaseLayout from "./base.astro";
import Breadcrumbs from "../components/breadcrumbs.astro";
import { slugToTitleCase } from "../lib/utils";
import dayjs from "dayjs";
import relativeTime from "dayjs/plugin/relativeTime";
import peopleData from "../data/people.json";

dayjs.extend(relativeTime);

// Build a username→person lookup from people.json (flattened across all orgs)
type Person = { username: string; name: string; photo?: string; title?: string; 'profile-url'?: string };
const peopleLookup = new Map<string, Person>();
for (const org of Object.values(peopleData.orgs) as any[]) {
    for (const person of org.people) {
        if (person.username) peopleLookup.set(person.username, person);
    }
}

type Variant = "article" | "wide" | "full" | "sidebar";

interface Props {
    variant?: Variant;
    title?: string;
    date?: Date | string;
    cover?: {
        source: string;
        caption?: string;
        alt?: string;
    };
    breadcrumbs?: Array<{ label: string; href?: string }>;
    seo?: any;
    class?: string;
    frontmatter?: any;
}

const {
    variant = "wide",
    title,
    date,
    cover,
    breadcrumbs,
    seo,
    class: className = "",
    frontmatter,
} = Astro.props;

// If using MDX with frontmatter, merge those values
const finalVariant = frontmatter?.variant || variant;
const finalTitle = frontmatter?.title || title;
const finalDate = frontmatter?.date || date;
const rawCover = frontmatter?.cover || cover;
const finalSeo = frontmatter?.seo || seo;

// Content-type-specific metadata from frontmatter
const tags: string[] = frontmatter?.tags ?? [];
const summary: string | undefined = frontmatter?.summary;
const status: string | undefined = frontmatter?.status;
const category: string | undefined = frontmatter?.category;
const period: string | undefined = frontmatter?.period;
const funder: { name?: string | null; link?: string | null } | undefined = frontmatter?.funder;
const externalLink: string | undefined = frontmatter?.external_link;
const keywords: string[] = frontmatter?.keywords ?? [];

// Resolve authors for news articles
const authorNames: string[] = frontmatter?.authors ?? [];
type ResolvedAuthor = { name: string; photo: string; url?: string };
const defaultAuthor: ResolvedAuthor = {
    name: 'ELIXIR Norway',
    photo: `${import.meta.env.BASE_URL.replace(/\/$/, '')}/assets/logos/elixir-no-avatar.png`,
};
const namedAuthors: ResolvedAuthor[] = authorNames.map(username => {
    const person = peopleLookup.get(username);
    if (person) {
        return {
            name: person.name,
            photo: person.photo ?? defaultAuthor.photo,
            url: person['profile-url'] ?? undefined,
        };
    }
    return { name: username, photo: defaultAuthor.photo };
});
// ELIXIR Norway is always an author — named authors come first
const resolvedAuthors: ResolvedAuthor[] = [...namedAuthors, defaultAuthor];

// Detect content type from URL
const pathname = Astro.url.pathname;
const contentType = pathname.startsWith('/news/') ? 'news'
    : pathname.startsWith('/events/') ? 'events'
    : pathname.startsWith('/funding-and-projects/') ? 'projects'
    : null;

// Resolve relative asset paths (./file.png) to their public URL using the page pathname
function resolvePageAsset(src: string): string {
    if (!src?.startsWith('./')) return src;
    const base = import.meta.env.BASE_URL.replace(/\/$/, '');
    const cleanPathname = Astro.url.pathname.replace(/\/$/, '');
    const contentPath = base && cleanPathname.startsWith(base) ? cleanPathname.slice(base.length) : cleanPathname;
    return `${base}/content${contentPath}/${src.slice(2)}`;
}
const finalCover = rawCover
    ? { ...rawCover, source: resolvePageAsset(rawCover.source) }
    : undefined;

// Convert string date to Date if needed
const dateObj = finalDate
    ? typeof finalDate === "string"
        ? new Date(finalDate)
        : finalDate
    : null;

const formattedDate = dateObj
    ? dateObj.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })
    : null;

const relativeDate = dateObj ? dayjs(dateObj).fromNow() : null;

// Period relative label for projects
function periodToRelative(p: string): string {
    const matches = p.match(/(\d{4}-\d{2})/g);
    if (!matches || matches.length < 2) return p;
    const end = dayjs(matches[matches.length - 1]);
    if (!end.isValid()) return p;
    const now = dayjs();
    if (end.isAfter(now)) return end.fromNow(true) + ' to deadline';
    return 'Completed ' + end.fromNow();
}

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');

// Status badge colors (reused from listing page)
const statusColors: Record<string, { bg: string; text: string; dot: string }> = {
    ongoing: {
        bg: 'bg-green-100 dark:bg-green-900/20',
        text: 'text-green-700 dark:text-green-400',
        dot: 'bg-green-500 dark:bg-green-400',
    },
    completed: {
        bg: 'bg-gray-100 dark:bg-gray-800/40',
        text: 'text-gray-600 dark:text-gray-400',
        dot: 'bg-gray-400 dark:bg-gray-500',
    },
};

const categoryColors: Record<string, string> = {
    european: 'bg-blue-100 dark:bg-blue-900/20 text-blue-700 dark:text-blue-400',
    elixir: 'bg-accent/10 text-accent',
    norwegian: 'bg-red-100 dark:bg-red-900/20 text-red-700 dark:text-red-400',
    global: 'bg-purple-100 dark:bg-purple-900/20 text-purple-700 dark:text-purple-400',
};

// Max width classes based on variant
const containerClasses = {
    article: "max-w-3xl",
    wide: "max-w-5xl",
    full: "max-w-7xl",
    sidebar: "max-w-6xl",
};

const hasSidebar = finalVariant === "sidebar";

// Merge SEO data — enrich with content-type-specific metadata
const siteUrl = 'https://elixir.no';
const coverImageUrl = finalCover ? `${siteUrl}${finalCover.source}` : undefined;
const mergedSeo = {
    ...finalSeo,
    title: finalSeo?.title || finalTitle,
    description: finalSeo?.description || summary,
    ...(coverImageUrl && { image: coverImageUrl }),
    ...(contentType === 'news' && {
        article: true,
        author: resolvedAuthors.map(a => a.name).join(', '),
        publishedTime: dateObj?.toISOString(),
        tags,
    }),
    ...(contentType === 'events' && {
        article: true,
        publishedTime: dateObj?.toISOString(),
    }),
};

// JSON-LD structured data
const publisherLd = {
    '@type': 'Organization' as const,
    name: 'ELIXIR Norway',
    url: siteUrl,
    logo: { '@type': 'ImageObject' as const, url: `${siteUrl}/assets/logos/elixir-no-dark.svg` },
};

const jsonLd = contentType === 'news' ? JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'NewsArticle',
    headline: finalTitle,
    description: summary,
    datePublished: dateObj?.toISOString(),
    image: coverImageUrl,
    author: resolvedAuthors.map(a => ({
        '@type': a.name === 'ELIXIR Norway' ? 'Organization' : 'Person',
        name: a.name,
        ...(a.url ? { url: a.url } : {}),
    })),
    publisher: publisherLd,
}) : contentType === 'events' ? JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Event',
    name: finalTitle,
    description: summary,
    startDate: dateObj?.toISOString(),
    image: coverImageUrl,
    organizer: publisherLd,
}) : contentType === 'projects' ? JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'ResearchProject',
    name: finalTitle,
    description: summary,
    ...(funder?.name && { funder: { '@type': 'Organization', name: funder.name, ...(funder.link ? { url: funder.link } : {}) } }),
    ...(externalLink && { url: externalLink }),
    ...(keywords.length > 0 && { keywords: keywords.join(', ') }),
}) : null;
---

<BaseLayout seo={mergedSeo}>
    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}
    <div class="isolate px-6 sm:px-8 pb-12 pt-24 sm:pt-28 flex-1">
        <div class={`mx-auto ${containerClasses[finalVariant]}`}>
            <!-- Breadcrumbs -->
            {breadcrumbs && <Breadcrumbs crumbs={breadcrumbs} />}
            <!-- Page Header -->
            {
                (finalTitle || finalCover) && (
                    <header class="mb-10 sm:mb-14">
                        {/* Back link */}
                        {contentType && (
                            <a
                                href={`${BASE}/${contentType === 'projects' ? 'funding-and-projects' : contentType}`}
                                class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-brand-primary dark:hover:text-white transition-colors mb-6"
                            >
                                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
                                </svg>
                                {contentType === 'news' ? 'All news' : contentType === 'events' ? 'All events' : 'All projects'}
                            </a>
                        )}

                        {/* Badges row — news tags, project status/category */}
                        {contentType === 'news' && tags.length > 0 && (
                            <div class="flex flex-wrap gap-2 mb-4">
                                {tags.map((tag: string) => (
                                    <span class="rounded-full px-3 py-1 text-xs font-semibold bg-accent/10 text-accent">
                                        {slugToTitleCase(tag)}
                                    </span>
                                ))}
                            </div>
                        )}

                        {contentType === 'projects' && (status || category) && (
                            <div class="flex flex-wrap items-center gap-2 mb-4">
                                {status && status !== 'unknown' && (() => {
                                    const sc = statusColors[status] ?? statusColors.completed;
                                    return (
                                        <span class={`inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-semibold ${sc.bg} ${sc.text}`}>
                                            <span class={`h-1.5 w-1.5 rounded-full ${sc.dot}`} />
                                            {slugToTitleCase(status)}
                                        </span>
                                    );
                                })()}
                                {category && category !== 'unknown' && (
                                    <span class={`rounded-full px-3 py-1 text-xs font-semibold ${categoryColors[category] ?? 'bg-gray-100 dark:bg-gray-800/40 text-gray-600 dark:text-gray-400'}`}>
                                        {slugToTitleCase(category)}
                                    </span>
                                )}
                            </div>
                        )}

                        {finalTitle && (
                            <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight text-brand-primary dark:text-white text-balance leading-[1.15]">
                                {finalTitle}
                            </h1>
                        )}

                        {/* Author byline + date for news */}
                        {contentType === 'news' && (
                            <div class="mt-5 flex items-center gap-3">
                                {/* Stacked avatars */}
                                <div class="flex -space-x-2" aria-hidden="true">
                                    {resolvedAuthors.map((author) => (
                                        <img
                                            src={author.photo}
                                            alt=""
                                            class="h-9 w-9 rounded-full ring-2 ring-white dark:ring-dark-background object-cover"
                                            loading="lazy"
                                        />
                                    ))}
                                </div>
                                <div class="text-sm">
                                    <p class="font-medium text-brand-primary dark:text-white">
                                        {resolvedAuthors.map((author, i) => (
                                            <>
                                                {i > 0 && <span class="text-gray-500 dark:text-gray-400">, </span>}
                                                {author.url
                                                    ? <a href={author.url} target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">{author.name}</a>
                                                    : <span>{author.name}</span>
                                                }
                                            </>
                                        ))}
                                    </p>
                                    {dateObj && (
                                        <p class="text-gray-500 dark:text-gray-400">
                                            <time datetime={dateObj.toISOString()}>{formattedDate}</time>
                                            <span class="mx-1">&middot;</span>
                                            <span>{relativeDate}</span>
                                        </p>
                                    )}
                                </div>
                            </div>
                        )}

                        {/* Date row for non-news */}
                        {contentType !== 'news' && dateObj && (
                            <div class="mt-4 flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
                                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                                </svg>
                                <time datetime={dateObj.toISOString()}>
                                    {formattedDate}
                                </time>
                                <span class="text-gray-300 dark:text-gray-600">&middot;</span>
                                <span>{relativeDate}</span>
                            </div>
                        )}

                        {/* Project metadata row */}
                        {contentType === 'projects' && (period || funder?.name) && (
                            <div class="mt-4 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-gray-500 dark:text-gray-400">
                                {period && (
                                    <span class="inline-flex items-center gap-1.5" title={period}>
                                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                                        </svg>
                                        {periodToRelative(period)}
                                    </span>
                                )}
                                {funder?.name && (
                                    <span class="inline-flex items-center gap-1.5">
                                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21" />
                                        </svg>
                                        {funder.link
                                            ? <a href={funder.link} target="_blank" rel="noopener noreferrer" class="hover:text-brand-primary dark:hover:text-white transition-colors">{funder.name}</a>
                                            : funder.name
                                        }
                                    </span>
                                )}
                                {externalLink && (
                                    <a href={externalLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 hover:text-brand-primary dark:hover:text-white transition-colors">
                                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                                        </svg>
                                        Project website
                                    </a>
                                )}
                            </div>
                        )}

                        {/* Summary / lead paragraph */}
                        {summary && contentType && (
                            <p class="mt-5 text-base sm:text-lg leading-relaxed text-brand-grey dark:text-gray-300 text-balance">
                                {summary}
                            </p>
                        )}

                        {/* Project keywords */}
                        {contentType === 'projects' && keywords.length > 0 && (
                            <div class="mt-5 flex flex-wrap gap-2">
                                {keywords.map((kw: string) => (
                                    <span class="rounded-full px-2.5 py-0.5 text-xs font-medium bg-gray-100 dark:bg-gray-800/40 text-gray-600 dark:text-gray-400">
                                        {slugToTitleCase(kw)}
                                    </span>
                                ))}
                            </div>
                        )}

                        {/* Divider before cover or content */}
                        {!finalCover && <div class="mt-8 border-t border-gray-200/60 dark:border-gray-700/30" />}

                        {finalCover && (
                            <figure class="mt-8">
                                <img
                                    src={finalCover.source}
                                    alt={
                                        finalCover.alt ||
                                        finalTitle ||
                                        "Cover image"
                                    }
                                    class="w-full rounded-xl"
                                    loading="lazy"
                                />
                                {finalCover.caption && (
                                    <figcaption class="text-sm text-gray-500 dark:text-gray-400 mt-3 text-center">
                                        {finalCover.caption}
                                    </figcaption>
                                )}
                            </figure>
                        )}
                    </header>
                )
            }
            <!-- Main Content with Optional Left Sidebar -->
            {
                hasSidebar ? (
                    <div class="grid lg:grid-cols-[250px_1fr] xl:grid-cols-[280px_1fr] gap-16 items-start">
                        <aside
                            class="hidden lg:block"
                            aria-label="Sidebar navigation"
                        >
                            <div class="sticky top-24">
                                <slot name="sidebar" />
                            </div>
                        </aside>

                        <main id="main-content" class={`min-w-0 ${className}`}>
                            <slot />
                        </main>
                    </div>
                ) : (
                    <main id="main-content" class={className}>
                        <slot />
                    </main>
                )
            }
        </div>
    </div>
</BaseLayout>
