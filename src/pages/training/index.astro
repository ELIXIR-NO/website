---
import Page from "../../layouts/page.astro";

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Page variant="wide">

    <!-- TeSS widget CSS -->
    <link rel="stylesheet" href="https://elixirtess.github.io/TeSS_widgets/css/tess-widget.css" slot="head" />

    <!-- Hero -->
    <div class="max-w-3xl">
        <p class="text-sm font-semibold text-brand-secondary tracking-wide uppercase">Training</p>
        <h1 class="mt-3 text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-brand-primary dark:text-white leading-[1.15]">
            Bioinformatics training for&nbsp;every&nbsp;level
        </h1>
        <p class="mt-6 text-base sm:text-lg leading-relaxed text-brand-grey dark:text-gray-300 max-w-2xl">
            From introductory workshops to advanced domain-specific courses, ELIXIR Norway
            provides open-access training to support life science researchers across Norway and internationally.
        </p>
    </div>

    <!-- Training types grid -->
    <section class="mt-20">
        <h2 class="text-2xl font-bold text-brand-primary dark:text-white">Types of training</h2>
        <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">

            <!-- RDM -->
            <div class="rounded-xl border border-gray-200/60 dark:border-gray-700/30 bg-white dark:bg-white/[0.03] p-6">
                <div class="flex items-center gap-3 mb-3">
                    <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-blue-100 dark:bg-blue-900/20">
                        <svg class="h-5 w-5 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
                        </svg>
                    </div>
                    <h3 class="text-base font-semibold text-brand-primary dark:text-white">Research Data Management</h3>
                </div>
                <p class="text-sm leading-relaxed text-brand-grey dark:text-gray-400">
                    General RDM courses covering data collection, metadata management, sensitive data regulations, and FAIR data handling best practices.
                </p>
            </div>

            <!-- Tool-specific -->
            <div class="rounded-xl border border-gray-200/60 dark:border-gray-700/30 bg-white dark:bg-white/[0.03] p-6">
                <div class="flex items-center gap-3 mb-3">
                    <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-brand-secondary/10 dark:bg-brand-secondary/10">
                        <svg class="h-5 w-5 text-brand-secondary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.049.58.025 1.193-.14 1.743" />
                        </svg>
                    </div>
                    <h3 class="text-base font-semibold text-brand-primary dark:text-white">Tool-Specific Courses</h3>
                </div>
                <p class="text-sm leading-relaxed text-brand-grey dark:text-gray-400">
                    Hands-on training for <a href="https://nels.bioinfo.no/" class="text-brand-secondary hover:underline">NeLS</a>, <a href="https://galaxyproject.org/use/usegalaxy-no/" class="text-brand-secondary hover:underline">UseGalaxy</a>, <a href="https://norway.dsw.elixir-europe.org/wizard/" class="text-brand-secondary hover:underline">Data Stewardship Wizard</a>, <a href="https://ega.elixir.no/" class="text-brand-secondary hover:underline">FEGA-Norway</a>, and other tools in the ELIXIR ecosystem.
                </p>
            </div>

            <!-- Domain-specific -->
            <div class="rounded-xl border border-gray-200/60 dark:border-gray-700/30 bg-white dark:bg-white/[0.03] p-6">
                <div class="flex items-center gap-3 mb-3">
                    <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-green-100 dark:bg-green-900/20">
                        <svg class="h-5 w-5 text-green-600 dark:text-green-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
                        </svg>
                    </div>
                    <h3 class="text-base font-semibold text-brand-primary dark:text-white">Domain-Specific Courses</h3>
                </div>
                <p class="text-sm leading-relaxed text-brand-grey dark:text-gray-400">
                    Specialised training in single-cell sequencing, microbiome analysis, biodiversity studies, genome assembly, and more.
                </p>
            </div>

            <!-- Train-the-Trainer -->
            <div class="rounded-xl border border-gray-200/60 dark:border-gray-700/30 bg-white dark:bg-white/[0.03] p-6">
                <div class="flex items-center gap-3 mb-3">
                    <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-purple-100 dark:bg-purple-900/20">
                        <svg class="h-5 w-5 text-purple-600 dark:text-purple-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
                        </svg>
                    </div>
                    <h3 class="text-base font-semibold text-brand-primary dark:text-white">Train-the-Trainer</h3>
                </div>
                <p class="text-sm leading-relaxed text-brand-grey dark:text-gray-400">
                    Part of the <a href="https://elixir-europe.org/platforms/training/train-the-trainer" class="text-brand-secondary hover:underline">ELIXIR-GOBLET TtT programme</a> — learn teaching techniques for productive learner engagement and effective course design.
                </p>
            </div>

        </div>
    </section>

    <!-- Resources -->
    <section class="mt-20">
        <h2 class="text-2xl font-bold text-brand-primary dark:text-white">Find courses and materials</h2>
        <p class="mt-3 text-sm leading-relaxed text-brand-grey dark:text-gray-400 max-w-2xl">
            Browse our catalogue of available courses, categorised by topic and proficiency level.
            All training materials are open-access.
        </p>
        <div class="mt-8 grid grid-cols-1 sm:grid-cols-3 gap-4">
            <a href="https://tess.elixir-europe.org/" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-3 rounded-xl border border-gray-200/60 dark:border-gray-700/30 bg-white dark:bg-white/[0.03] p-4 transition-all duration-200 hover:border-brand-secondary/30 hover:shadow-md">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-primary/5 dark:bg-brand-primary/10">
                    <svg class="h-5 w-5 text-brand-primary dark:text-brand-secondary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
                    </svg>
                </div>
                <div class="min-w-0">
                    <p class="text-sm font-semibold text-brand-primary dark:text-white group-hover:text-brand-secondary transition-colors">ELIXIR TeSS</p>
                    <p class="text-xs text-brand-grey/60 dark:text-gray-500">Course catalogue</p>
                </div>
                <svg class="ml-auto h-4 w-4 shrink-0 text-brand-grey/30 dark:text-gray-600 group-hover:text-brand-secondary transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                </svg>
            </a>
            <a href="https://github.com/ELIXIR-Norway-Training" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-3 rounded-xl border border-gray-200/60 dark:border-gray-700/30 bg-white dark:bg-white/[0.03] p-4 transition-all duration-200 hover:border-brand-secondary/30 hover:shadow-md">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-primary/5 dark:bg-brand-primary/10">
                    <svg class="h-5 w-5 text-brand-primary dark:text-brand-secondary" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                    </svg>
                </div>
                <div class="min-w-0">
                    <p class="text-sm font-semibold text-brand-primary dark:text-white group-hover:text-brand-secondary transition-colors">GitHub</p>
                    <p class="text-xs text-brand-grey/60 dark:text-gray-500">Training materials</p>
                </div>
                <svg class="ml-auto h-4 w-4 shrink-0 text-brand-grey/30 dark:text-gray-600 group-hover:text-brand-secondary transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                </svg>
            </a>
            <a href="https://zenodo.org/communities/elixir-no/records?q=&f=resource_type%3Alesson&f=resource_type%3Apresentation&l=list&p=1&s=10&sort=newest" target="_blank" rel="noopener noreferrer" class="group flex items-center gap-3 rounded-xl border border-gray-200/60 dark:border-gray-700/30 bg-white dark:bg-white/[0.03] p-4 transition-all duration-200 hover:border-brand-secondary/30 hover:shadow-md">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-brand-primary/5 dark:bg-brand-primary/10">
                    <svg class="h-5 w-5 text-brand-primary dark:text-brand-secondary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
                    </svg>
                </div>
                <div class="min-w-0">
                    <p class="text-sm font-semibold text-brand-primary dark:text-white group-hover:text-brand-secondary transition-colors">Zenodo</p>
                    <p class="text-xs text-brand-grey/60 dark:text-gray-500">Archived materials</p>
                </div>
                <svg class="ml-auto h-4 w-4 shrink-0 text-brand-grey/30 dark:text-gray-600 group-hover:text-brand-secondary transition-colors" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                </svg>
            </a>
        </div>
    </section>

    <!-- Upcoming training (TeSS widget) -->
    <section class="mt-20" id="upcoming-events">
        <div class="flex items-center gap-3 mb-6">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-green-100 dark:bg-green-900/20 px-3 py-1 text-xs font-semibold text-green-700 dark:text-green-400">
                <span class="h-1.5 w-1.5 rounded-full bg-green-500 dark:bg-green-400 animate-pulse"></span>
                Live
            </span>
            <h2 class="text-2xl font-bold text-brand-primary dark:text-white">Upcoming training</h2>
        </div>
        <div class="rounded-xl border border-gray-200/60 dark:border-gray-700/30 bg-white dark:bg-white/[0.03] p-6 tess-container">
            <div id="tess-widget-events-list" class="tess-widget tess-widget-list"></div>
            <div id="tess-widget-events-list-placeholder" class="hidden items-center justify-center py-10 text-sm text-brand-grey/60 dark:text-gray-500">
                <svg class="mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                </svg>
                No upcoming training events at the moment.
            </div>
        </div>
    </section>

    <!-- Training material (TeSS widget) -->
    <section class="mt-16" id="training-material">
        <h2 class="text-2xl font-bold text-brand-primary dark:text-white mb-6">Training materials</h2>
        <div class="rounded-xl border border-gray-200/60 dark:border-gray-700/30 bg-white dark:bg-white/[0.03] p-6 tess-container">
            <div id="training-materials-list" class="tess-widget tess-widget-list"></div>
        </div>
    </section>

    <!-- Past events (TeSS widget) -->
    <section class="mt-16" id="past-events">
        <h2 class="text-2xl font-bold text-brand-primary dark:text-white mb-6">Past training events</h2>
        <div class="rounded-xl border border-gray-200/60 dark:border-gray-700/30 bg-white dark:bg-white/[0.03] p-6 tess-container">
            <div id="past-training-materials-list" class="tess-widget tess-widget-list"></div>
        </div>
    </section>

    <!-- TeSS widget scripts -->
    <script is:inline src="https://elixirtess.github.io/TeSS_widgets/js/tess-widget-standalone.js"></script>
    <script is:inline>
        function initTeSSWidgets() {
            if (typeof TessWidget === 'undefined') return;
            TessWidget.Events(document.getElementById('tess-widget-events-list'), 'SimpleList', {
                params: { pageSize: 5, country: ['Norway'] }
            });
            setTimeout(function() {
                var container = document.getElementById('tess-widget-events-list');
                var placeholder = document.getElementById('tess-widget-events-list-placeholder');
                if (!container || !placeholder) return;
                var hasContent = Array.from(container.children).some(function(child) {
                    return child.tagName !== 'UL' || (child.tagName === 'UL' && child.children.length > 0);
                });
                if (!hasContent) {
                    container.style.display = 'none';
                    placeholder.style.display = 'flex';
                }
            }, 1500);
        }

        function initTrainingMaterials() {
            if (typeof TessWidget === 'undefined') return;
            TessWidget.Materials(document.getElementById('training-materials-list'), 'SimpleList', {
                opts: { enableSearch: true },
                params: { pageSize: 10, node: ['Norway'] }
            });
        }

        function initPastTrainingMaterials() {
            if (typeof TessWidget === 'undefined') return;
            TessWidget.Events(document.getElementById('past-training-materials-list'), 'SimpleList', {
                params: { pageSize: 10, country: ['Norway'], sort: 'new', includeExpired: true, includeDisabled: false }
            });
        }

        // Init when TeSS script loads — try immediately, then on load
        if (typeof TessWidget !== 'undefined') {
            initTeSSWidgets();
            initTrainingMaterials();
            initPastTrainingMaterials();
        } else {
            document.addEventListener('DOMContentLoaded', function() {
                setTimeout(function() {
                    initTeSSWidgets();
                    initTrainingMaterials();
                    initPastTrainingMaterials();
                }, 500);
            });
        }
    </script>

    <!-- TeSS widget style overrides -->
    <style is:global>
        .tess-container .tess-widget ul {
            list-style: none !important;
            padding: 0 !important;
            margin: 0 !important;
        }
        .tess-container .tess-widget li {
            border-bottom: 1px solid rgba(0, 0, 0, 0.06);
            padding: 0.75rem 0;
        }
        .tess-container .tess-widget li:last-child {
            border-bottom: none;
        }
        .tess-container .tess-widget a {
            color: #023452;
            font-weight: 500;
            text-decoration: none;
        }
        .tess-container .tess-widget a:hover {
            color: #f47d20;
        }
        .dark .tess-container .tess-widget a {
            color: #f47d20;
        }
        .dark .tess-container .tess-widget a:hover {
            color: #f9a75e;
        }
        .dark .tess-container .tess-widget li {
            border-color: rgba(255, 255, 255, 0.06);
        }
        .dark .tess-container .tess-widget,
        .dark .tess-container .tess-widget * {
            color: #d1d5db;
        }
        /* Search controls — make full width */
        .tess-container .tess-widget .tess-controls {
            display: flex !important;
            width: 100% !important;
            margin-bottom: 1rem !important;
        }
        .tess-container .tess-widget .tess-controls .tess-search {
            display: flex !important;
            width: 100% !important;
        }
        /* Light mode — input */
        .tess-container .tess-widget .tess-controls .tess-search input {
            width: 100% !important;
            flex: 1 !important;
            padding: 0.625rem 2rem 0.625rem 0.875rem !important;
            font-size: 0.875rem !important;
            line-height: 1.5 !important;
            color: #023452 !important;
            border: 1px solid #e5e7eb !important;
            border-radius: 0.75rem 0 0 0.75rem !important;
            background: #fff !important;
            outline: none !important;
            transition: border-color 0.15s, box-shadow 0.15s !important;
            box-sizing: border-box !important;
        }
        .tess-container .tess-widget .tess-controls .tess-search input::placeholder {
            color: #9ca3af !important;
        }
        .tess-container .tess-widget .tess-controls .tess-search input:focus {
            border-color: #f47d20 !important;
            box-shadow: 0 0 0 1px #f47d20 !important;
        }
        /* Light mode — button */
        .tess-container .tess-widget .tess-controls .tess-search button {
            padding: 0.625rem 1rem !important;
            font-size: 0.875rem !important;
            line-height: 1.5 !important;
            color: #023452 !important;
            border: 1px solid #e5e7eb !important;
            border-left: 0 !important;
            border-radius: 0 0.75rem 0.75rem 0 !important;
            background: #f9fafb !important;
            cursor: pointer !important;
            transition: background 0.15s, color 0.15s !important;
        }
        .tess-container .tess-widget .tess-controls .tess-search button:hover {
            background: #f47d20 !important;
            color: #fff !important;
            border-color: #f47d20 !important;
        }
        /* Light mode — clear link */
        .tess-container .tess-widget .tess-controls .tess-search .tess-search-clear {
            color: #9ca3af !important;
        }
        .tess-container .tess-widget .tess-controls .tess-search .tess-search-clear:hover {
            color: #023452 !important;
        }
        /* Dark mode — input */
        .dark .tess-container .tess-widget .tess-controls .tess-search input {
            color: #e5e7eb !important;
            border-color: rgba(255, 255, 255, 0.12) !important;
            background: rgba(255, 255, 255, 0.03) !important;
        }
        .dark .tess-container .tess-widget .tess-controls .tess-search input::placeholder {
            color: #6b7280 !important;
        }
        .dark .tess-container .tess-widget .tess-controls .tess-search input:focus {
            border-color: #f47d20 !important;
            box-shadow: 0 0 0 1px #f47d20 !important;
        }
        /* Dark mode — button */
        .dark .tess-container .tess-widget .tess-controls .tess-search button {
            color: #d1d5db !important;
            border-color: rgba(255, 255, 255, 0.12) !important;
            background: rgba(255, 255, 255, 0.05) !important;
        }
        .dark .tess-container .tess-widget .tess-controls .tess-search button:hover {
            background: #f47d20 !important;
            color: #fff !important;
            border-color: #f47d20 !important;
        }
        /* Dark mode — clear link */
