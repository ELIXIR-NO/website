---
import people from "../data/people.json";

type Org = {
    name: string;
    people: Person[];
}
type Person = {
    "name": string;
    "title": string;
    "photo": string;
    "profile-url": string;
    "affiliations": Array<{ name: string; role: string }>
    "elixir-groups": Array<{ name: string; role: string }>
}

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');

const {
    elixirGroup,
    org,
    hidePicture,
    layout = "default",
    hideOrg,
    isSummary = false
} = Astro.props;

function composeTitle(person: Person) {
    return [
        person.title,
        ...person["elixir-groups"].map(g => g.role).filter(Boolean),
        ...person["affiliations"].map(a => {
            if (a) return `${a?.role ? a.role + "—" : ''}${a.name}`;
        }),
    ]
        .filter(Boolean)
        .join(", ")
}

function getAllPeopleWithMetadata(data: { groups: any, orgs: { [key: string]: Org } }) {
    let allPeople = [];
    for (const [orgKey, org] of Object.entries(data.orgs)) {
        org.people.forEach(person => {
            const personWithMetadata = {
                ...person,
                "org-key": orgKey,
                "org-name": (org as Org).name,
                "full-title": composeTitle(person)
            };
            allPeople.push(personWithMetadata);
        });
    }
    return allPeople;
}

const sub = x => x?.name === elixirGroup;

const peopleWithMeta = getAllPeopleWithMetadata(people);

const filteredPeople = peopleWithMeta
    .filter(o => !org ? true : o["org-key"] === org)
    .filter(o => !elixirGroup ? true : o["elixir-groups"]?.find(sub));

const isFeatured = layout === "featured";

const gridClass = (() => {
    switch (layout) {
        case "featured": return "sm:grid-cols-2 lg:grid-cols-3 gap-4";
        case "three-col": return "sm:grid-cols-2 lg:grid-cols-3";
        case "two-col": return "sm:grid-cols-2";
        default: return "";
    }
})();

const groupLabels: Record<string, string> = {
    "node-leaders": "Node Leader",
    "coordinators": "Coordinator",
    "steering-board": "Steering Board",
    "scientific-advisory-committee": "Advisory Committee",
    "stakeholder-panel": "Stakeholder Panel",
};

function getElixirRole(person: any): string {
    if (!elixirGroup) return "";
    const match = person["elixir-groups"]?.find((g: any) => g.name === elixirGroup);
    return match?.role || groupLabels[elixirGroup] || "";
}
---

<Fragment>
    {isSummary ? (
        <a
            href={`${BASE}/about/everyone`}
            class="group block rounded-2xl border border-gray-200/60 dark:border-gray-700/30 bg-gradient-to-br from-brand-primary/[0.03] to-transparent dark:from-white/[0.03] p-8 sm:p-10 text-center transition-all duration-200 hover:border-accent/30 hover:shadow-lg hover:shadow-accent/[0.06] focus:outline-none focus-visible:ring-2 focus-visible:ring-accent mt-6"
        >
            <p class="text-sm font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                Our team
            </p>
            <p class="mt-2 text-2xl sm:text-3xl font-bold text-brand-primary dark:text-white tracking-tight">
                70+ researchers, engineers & scientists
            </p>
            <p class="mt-2 text-sm text-brand-grey dark:text-gray-400">
                Across five Norwegian universities
            </p>
            <span class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-accent">
                Meet the team
                <svg class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
            </span>
        </a>
    ) : (
        <ul class={`grid ${isFeatured ? '' : 'gap-3'} ${gridClass}`} role="list">
            {filteredPeople.map((person) => {
                const role = getElixirRole(person);
                return (
                    <li>
                        {isFeatured ? (
                            <a
                                href={person["profile-url"]}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="group flex flex-col items-center text-center rounded-xl border border-gray-200/60 dark:border-gray-700/30 bg-white dark:bg-white/[0.03] p-5 sm:p-6 shadow-sm ring-1 ring-black/[0.03] dark:ring-white/[0.03] transition-all duration-200 hover:border-accent/30 hover:shadow-lg hover:shadow-accent/[0.06] focus:outline-none focus-visible:ring-2 focus-visible:ring-accent"
                            >
                                <div class="h-16 w-16 sm:h-20 sm:w-20 shrink-0 overflow-hidden rounded-full border-2 border-gray-200/60 dark:border-gray-700/40 shadow-sm transition-transform duration-200 group-hover:scale-105">
                                    <img
                                        alt={person.name}
                                        src={`${BASE}${person.photo}`}
                                        class="h-full w-full object-cover"
                                        loading="lazy"
                                    />
                                </div>
                                <div class="mt-4 w-full">
                                    <div class="inline-block rounded-full bg-accent/10 px-2.5 py-0.5 text-xs font-semibold text-accent">
                                        {role}
                                    </div>
                                    <div class="mt-2 text-sm sm:text-base font-semibold text-brand-primary dark:text-white group-hover:text-accent transition-colors">
                                        {person.name}
                                    </div>
                                    <div class="mt-1 text-xs text-brand-grey dark:text-gray-400 leading-relaxed">
                                        {person.title}
                                    </div>
                                    <div class="mt-0.5 text-[11px] text-gray-500 dark:text-gray-400">
                                        {person["org-name"]}
                                    </div>
                                </div>
                            </a>
                        ) : (
                            <a
                                href={person["profile-url"]}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="group grid grid-cols-[auto_1fr] items-center gap-3 rounded-lg border border-gray-200/60 dark:border-gray-700/30 bg-white dark:bg-white/[0.03] p-3 shadow-sm ring-1 ring-black/[0.03] dark:ring-white/[0.03] transition-all duration-200 hover:border-accent/30 hover:shadow-md hover:shadow-accent/[0.06] focus:outline-none focus-visible:ring-2 focus-visible:ring-accent"
                            >
                                {!hidePicture && (
                                    <div class="h-11 w-11 shrink-0 overflow-hidden rounded-full border border-gray-200/60 dark:border-gray-700/40 shadow-sm transition-transform duration-200 group-hover:scale-105">
                                        <img
                                            alt={person.name}
                                            src={`${BASE}${person.photo}`}
                                            class="h-full w-full object-cover"
                                            loading="lazy"
                                        />
                                    </div>
                                )}
                                <div class="min-w-0">
                                    <div class="truncate text-sm font-semibold text-brand-primary dark:text-white group-hover:text-accent transition-colors">
                                        {person.name}
                                    </div>
                                    <div class="truncate text-xs text-brand-grey dark:text-gray-400 mt-0.5">
                                        {person["full-title"]}
                                    </div>
                                    {!hideOrg && (
                                        <div class="truncate text-[11px] text-gray-500 dark:text-gray-400 mt-0.5">
                                            {person["org-name"]}
                                        </div>
                                    )}
                                </div>
                            </a>
                        )}
                    </li>
                );
            })}
        </ul>
    )}
</Fragment>
