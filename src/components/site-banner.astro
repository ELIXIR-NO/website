---
import banner from "../data/banner.json";

const { visible, message } = banner;
if (!visible || !message) return;

function renderInlineMarkdown(md: string): string {
    return md
        .replace(/\*\*(.+?)\*\*/g, '<strong class="font-semibold">$1</strong>')
        .replace(/\*(.+?)\*/g, '<em>$1</em>')
        .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" class="underline underline-offset-2 hover:text-white/70 transition-colors">$1</a>');
}
---

<div
    id="site-banner"
    class="sticky top-0 z-[60] bg-accent text-sm [&_*]:!text-white shadow-md shadow-black/10 banner-slide-down"
    role="status"
>
    <div class="mx-auto max-w-7xl px-6 py-2 flex items-center justify-center gap-3 relative">
        <svg class="h-4 w-4 shrink-0 opacity-80 banner-pulse" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 1 1 0-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 0 1-1.44-4.282m3.102.069a18.03 18.03 0 0 1-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 0 1 8.835 2.535M10.34 6.66a23.847 23.847 0 0 0 8.835-2.535m0 0A23.74 23.74 0 0 0 18.795 3m.38 1.125a23.91 23.91 0 0 1 1.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 0 0 1.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 0 1 0 3.46" />
        </svg>
        <p set:html={renderInlineMarkdown(message)} />
        <button
            onclick="document.getElementById('site-banner').remove(); sessionStorage.setItem('banner-dismissed','1')"
            class="fixed right-3 top-1 p-1 rounded-md !text-white/60 hover:!text-white hover:bg-white/10 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-white/50 z-[61]"
            aria-label="Dismiss announcement"
        >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
    </div>
</div>

<style>
    @keyframes bannerSlideDown {
        from { transform: translateY(-100%); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }
    .banner-slide-down { animation: bannerSlideDown 0.6s ease-out; }
    @keyframes bannerPulse {
        0%, 100% { transform: scale(1); opacity: 0.8; }
        50% { transform: scale(1.15); opacity: 1; }
    }
    .banner-pulse { animation: bannerPulse 2s ease-in-out infinite; }
    @media (prefers-reduced-motion: reduce) { .banner-pulse, .banner-slide-down { animation: none; } }
</style>

<script is:inline>
    if (sessionStorage.getItem('banner-dismissed') === '1') {
        const b = document.getElementById('site-banner');
        if (b) b.remove();
    }
</script>
