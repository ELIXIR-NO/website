---
import { getCollection } from "astro:content";

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');

const news = (await getCollection("news"))
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
    .slice(0, 3);

function resolveCoverUrl(articleId: string, coverSource: string): string {
    const dir = articleId.replace(/\/?index(\.mdx?)?$/, '');
    const file = coverSource.replace(/^\.\//, '');
    return `${BASE}/content/news/${dir}/${file}`;
}

function formatDate(dateStr: string): string {
    const d = new Date(dateStr);
    if (isNaN(d.getTime())) return dateStr;
    return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
}

function articleUrl(id: string): string {
    const clean = id.replace(/\.mdx?$/, '').replace(/\/index$/, '');
    return `${BASE}/news/${clean}`;
}

const [featured, ...rest] = news;
const featuredCover = featured?.data.cover?.source
    ? resolveCoverUrl(featured.id, featured.data.cover.source)
    : null;
---

<section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
        <div class="flex items-end justify-between mb-12">
            <div>
                <h2 class="text-3xl font-bold tracking-tight text-brand-primary dark:text-white sm:text-4xl">
                    Latest News
                </h2>
                <p class="mt-3 text-lg text-brand-grey dark:text-gray-300">
                    Stay updated with the latest from ELIXIR Norway.
                </p>
            </div>
            <a
                href={`${BASE}/news`}
                class="hidden sm:inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-accent hover:bg-accent/5 rounded-lg transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-accent"
            >
                View all news
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
            </a>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 lg:gap-8">
            {/* Featured article — large card with image */}
            {featured && (
                <a
                    href={articleUrl(featured.id)}
                    class="group relative flex flex-col justify-end min-h-[360px] lg:min-h-[420px] rounded-2xl lg:rounded-3xl overflow-hidden focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
                >
                    {/* Background */}
                    {featuredCover ? (
                        <img
                            src={featuredCover}
                            alt=""
                            aria-hidden="true"
                            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                            loading="lazy"
                        />
                    ) : (
                        <div class="absolute inset-0 bg-gradient-to-br from-brand-primary to-brand-primary/80" />
                    )}

                    {/* Gradient overlay — opaque enough at bottom to guarantee WCAG contrast for text */}
                    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-black/5" />

                    {/* Content */}
                    <div class="relative p-6 sm:p-8">
                        <time class="text-xs font-semibold text-white/90 mb-3 block">
                            {formatDate(featured.data.date)}
                        </time>
                        <h3 class="text-xl sm:text-2xl font-bold text-white leading-snug mb-3 group-hover:text-brand-secondary transition-colors">
                            {featured.data.title}
                        </h3>
                        <p class="text-sm text-gray-200 leading-relaxed line-clamp-2 max-w-lg">
                            {featured.data.summary}
                        </p>
                        <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-white group-hover:text-brand-secondary transition-colors">
                            Read article
                            <svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                            </svg>
                        </span>
                    </div>
                </a>
            )}

            {/* Secondary articles — stacked text cards */}
            <div class="flex flex-col gap-6 lg:gap-8 justify-center">
                {rest.map((article) => {
                    const hasCover = !!article.data.cover?.source;
                    const coverUrl = hasCover ? resolveCoverUrl(article.id, article.data.cover!.source) : null;

                    return (
                        <a
                            href={articleUrl(article.id)}
                            class="group flex gap-5 items-start py-6 border-b border-gray-200/80 dark:border-gray-700/40 last:border-0 focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 rounded-lg"
                        >
                            {/* Thumbnail */}
                            {hasCover && (
                                <div class="hidden sm:block flex-shrink-0 w-28 h-20 rounded-xl overflow-hidden bg-gray-100 dark:bg-dark-surface">
                                    <img
                                        src={coverUrl}
                                        alt=""
                                        aria-hidden="true"
                                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                                        loading="lazy"
                                    />
                                </div>
                            )}

                            <div class="flex-1 min-w-0">
                                <time class="text-xs font-semibold text-accent mb-1.5 block">
                                    {formatDate(article.data.date)}
                                </time>
                                <h3 class="text-base font-bold text-brand-primary dark:text-white leading-snug group-hover:text-accent transition-colors line-clamp-2">
                                    {article.data.title}
                                </h3>
                                <p class="mt-1.5 text-sm text-brand-grey dark:text-gray-400 leading-relaxed line-clamp-2">
                                    {article.data.summary}
                                </p>
                            </div>

                            <svg class="flex-shrink-0 h-5 w-5 text-gray-500 dark:text-gray-400 group-hover:text-accent transition-all group-hover:translate-x-1 mt-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
                            </svg>
                        </a>
                    );
                })}
            </div>
        </div>

        {/* Mobile "View all" */}
        <div class="mt-8 text-center sm:hidden">
            <a
                href={`${BASE}/news`}
                class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-semibold text-accent hover:bg-accent/5 rounded-lg transition-colors"
            >
                View all news
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
            </a>
        </div>
    </div>
</section>
