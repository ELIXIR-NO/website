---
import BaseLayout from "../layouts/base.astro";
import Hero from "../components/hero.tsx";
import ServicesOverview from "../components/sections/services-overview.tsx";
import LatestNews from "../components/sections/latest-news.astro";
import HighlightsCarousel from "../components/highlights-carousel.tsx";
import OrganisationMarquee from "../components/organisation-marquee.tsx";
import slides from "../data/slides.json";
---

<BaseLayout seo={{
    title: "ELIXIR Norway - Life Science Data Infrastructure",
    description: "Norwegian node of ELIXIR, the European infrastructure for life science data. Bioinformatics services, data management tools, training, and secure e-infrastructure for researchers.",
}}>
    <script type="application/ld+json" set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Organization',
        name: 'ELIXIR Norway',
        url: 'https://elixir.no',
        logo: 'https://elixir.no/assets/logos/elixir-no-dark.svg',
        description: 'Norwegian node of ELIXIR, the European infrastructure for life science data.',
        parentOrganization: {
            '@type': 'Organization',
            name: 'ELIXIR',
            url: 'https://elixir-europe.org',
        },
        sameAs: [
            'https://www.linkedin.com/company/elixir-norway',
        ],
    })} />
    <main id="main-content">
        <div class="min-h-[calc(100vh-84px)]">
            <Hero client:only="react" />
        </div>

        <section class="py-20 lg:py-28 bg-light-surface dark:bg-dark-surface">
            <div class="max-w-[1400px] mx-auto px-4 sm:px-6">
                <div class="text-center mb-12">
                    <h2 class="text-3xl font-bold tracking-tight text-brand-primary dark:text-white sm:text-4xl">
                        Highlights
                    </h2>
                    <p class="mt-3 text-lg text-brand-grey dark:text-gray-300">
                        Recent events, milestones, and initiatives from our network.
                    </p>
                </div>
                <HighlightsCarousel slides={slides} client:visible />
            </div>
        </section>

        <ServicesOverview client:only="react" />

        <LatestNews />

        <OrganisationMarquee client:visible />
    </main>
</BaseLayout>
