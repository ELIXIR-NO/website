---
import Page from "../../layouts/page.astro";
import { getCollection } from "astro:content";
import { idToSlug, resolveContentAsset } from "../../lib/utils";

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');

function parseDate(dateString: string): number {
    const parsed = new Date(Date.parse(dateString));
    return isNaN(parsed.getTime()) ? 0 : parsed.getTime();
}

const now = Date.now();
const events = await getCollection("events");
events.sort((a, b) => parseDate(b.data.date) - parseDate(a.data.date));

const upcoming = events.filter(e => parseDate(e.data.date) >= now);
const past = events.filter(e => parseDate(e.data.date) < now);

function formatDate(dateString: string): string {
    const d = new Date(Date.parse(dateString));
    if (isNaN(d.getTime())) return dateString;
    return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<Page variant="wide">

    <!-- Hero -->
    <div class="max-w-3xl">
        <p class="text-sm font-semibold text-brand-secondary-text dark:text-brand-secondary tracking-wide uppercase">Events</p>
        <h1 class="mt-3 text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-brand-primary dark:text-white leading-[1.15]">
            Workshops, seminars, and community gatherings
        </h1>
        <p class="mt-6 text-base sm:text-lg leading-relaxed text-brand-grey dark:text-gray-300 max-w-2xl">
            Join ELIXIR Norway at events across the country — from hands-on bioinformatics
            workshops to international conferences and public panel debates.
        </p>
    </div>

    <!-- Upcoming events -->
    {upcoming.length > 0 && (
        <section class="mt-16">
            <div class="flex items-center gap-3 mb-8">
                <span class="inline-flex items-center gap-1.5 rounded-full bg-green-100 dark:bg-green-900/20 px-3 py-1 text-xs font-semibold text-green-700 dark:text-green-400">
                    <span class="h-1.5 w-1.5 rounded-full bg-green-500 dark:bg-green-400 animate-pulse" />
                    Upcoming
                </span>
                <h2 class="text-xl font-semibold text-brand-primary dark:text-white">Upcoming events</h2>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
                {upcoming.map((event) => {
                    const slug = idToSlug(event.id);
                    const cover = event.data?.cover?.source
                        ? resolveContentAsset(`${event.collection}/${event.id}`, event.data.cover.source)
                        : null;
                    return (
                        <a
                            href={`${BASE}/events/${slug}`}
                            class="group relative flex flex-col rounded-xl border border-green-200/60 dark:border-green-700/20 bg-white dark:bg-white/[0.03] overflow-hidden transition-[border-color,box-shadow] duration-200 hover:border-brand-secondary/40 hover:shadow-[0_0_0_3px_rgba(244,125,32,0.08)] focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary"
                        >
                            {cover ? (
                                <div class="h-40 bg-gray-50 dark:bg-white/5 overflow-hidden">
                                    <img
                                        src={cover}
                                        alt={event.data.title}
                                        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                                        loading="lazy"
                                    />
                                </div>
                            ) : (
                                <div class="h-40 bg-gradient-to-br from-brand-primary/5 to-brand-secondary/10 dark:from-brand-primary/10 dark:to-brand-secondary/5 flex items-center justify-center">
                                    <svg class="h-10 w-10 text-brand-secondary/30" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" aria-hidden="true">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                                    </svg>
                                </div>
                            )}
                            <div class="flex flex-col flex-1 p-5">
                                <time class="text-xs font-medium text-brand-secondary-text dark:text-brand-secondary">
                                    {formatDate(event.data.date)}
                                </time>
                                <h3 class="mt-2 text-base font-semibold text-brand-primary dark:text-white group-hover:text-brand-secondary-text dark:group-hover:text-brand-secondary transition-colors line-clamp-2">
                                    {event.data.title}
                                </h3>
                                <p class="mt-2 text-sm leading-relaxed text-brand-grey dark:text-gray-400 line-clamp-3 flex-1">
                                    {event.data.summary}
                                </p>
                                <div class="mt-4 flex items-center gap-1 text-xs font-medium text-gray-500 dark:text-gray-400 group-hover:text-brand-secondary-text dark:group-hover:text-brand-secondary transition-colors">
                                    View details
                                    <svg class="h-3 w-3 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                                    </svg>
                                </div>
                            </div>
                        </a>
                    );
                })}
            </div>
        </section>
    )}

    <!-- Past events -->
    {past.length > 0 && (
        <section class={upcoming.length > 0 ? "mt-16" : "mt-12"}>
            <h2 class="text-xl font-semibold text-brand-primary dark:text-white mb-8">Past events</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
                {past.map((event) => {
                    const slug = idToSlug(event.id);
                    const cover = event.data?.cover?.source
                        ? resolveContentAsset(`${event.collection}/${event.id}`, event.data.cover.source)
                        : null;
                    return (
                        <a
                            href={`${BASE}/events/${slug}`}
                            class="group relative flex flex-col rounded-xl border border-gray-200/60 dark:border-gray-700/30 bg-white dark:bg-white/[0.03] overflow-hidden transition-[border-color,box-shadow] duration-200 hover:border-brand-secondary/40 hover:shadow-[0_0_0_3px_rgba(244,125,32,0.08)] focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary"
                        >
                            {cover ? (
                                <div class="h-40 bg-gray-50 dark:bg-white/5 overflow-hidden">
                                    <img
                                        src={cover}
                                        alt={event.data.title}
                                        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                                        loading="lazy"
                                    />
                                </div>
                            ) : (
                                <div class="h-40 bg-gradient-to-br from-gray-50 to-gray-100 dark:from-white/[0.02] dark:to-white/[0.05] flex items-center justify-center">
                                    <svg class="h-10 w-10 text-gray-300 dark:text-gray-700" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" aria-hidden="true">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                                    </svg>
                                </div>
                            )}
                            <div class="flex flex-col flex-1 p-5">
                                <time class="text-xs font-medium text-brand-grey/60 dark:text-gray-500">
                                    {formatDate(event.data.date)}
                                </time>
                                <h3 class="mt-2 text-base font-semibold text-brand-primary dark:text-white group-hover:text-brand-secondary-text dark:group-hover:text-brand-secondary transition-colors line-clamp-2">
                                    {event.data.title}
                                </h3>
                                <p class="mt-2 text-sm leading-relaxed text-brand-grey dark:text-gray-400 line-clamp-3 flex-1">
                                    {event.data.summary}
                                </p>
                                <div class="mt-4 flex items-center gap-1 text-xs font-medium text-gray-500 dark:text-gray-400 group-hover:text-brand-secondary-text dark:group-hover:text-brand-secondary transition-colors">
                                    View details
                                    <svg class="h-3 w-3 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                                    </svg>
                                </div>
                            </div>
                        </a>
                    );
                })}
            </div>
        </section>
    )}

    <!-- Empty state -->
    {events.length === 0 && (
        <div class="mt-16 text-center py-20">
            <svg class="mx-auto h-12 w-12 text-brand-grey/20" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
            </svg>
            <p class="mt-4 text-brand-grey dark:text-gray-400">No events scheduled at this time.</p>
        </div>
    )}

</Page>
